# Copy this file to .env and fill in the values.

# Database
DATABASE_URL=postgresql://localhost:5432/prozen

# Anthropic (used for AI structuring and internal compression fallback)
ANTHROPIC_API_KEY=sk-ant-...

# The Token Company — context compression provider
TOKEN_COMPANY_ENABLED=false
TOKEN_COMPANY_API_KEY=
TOKEN_COMPANY_MODEL=bear-1.2
TOKEN_COMPANY_AGGRESSIVENESS=0.15
TOKEN_COMPANY_TIMEOUT_MS=2500

# Clerk — authentication
CLERK_SECRET_KEY=

# CORS allowlist for frontend origins (comma-separated)
# Example:
# ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100
ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
