{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prozen.app/schemas/context-pack.schema.json",
  "title": "PROZEN Context Pack Version",
  "description": "Canonical schema for versioned Context Pack snapshots",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contextPackId",
    "workspaceId",
    "productId",
    "version",
    "source",
    "summary",
    "sections",
    "decisionReferences",
    "compression",
    "createdAt",
    "createdBy"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "contextPackId": {
      "type": "string",
      "pattern": "^cp_[a-zA-Z0-9_-]{3,64}$"
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{3,64}$"
    },
    "productId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{3,64}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "source": {
      "type": "string",
      "enum": ["manual_input", "ai_structured", "restored", "compressed"]
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1200
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productVision",
        "targetUsers",
        "goals",
        "constraints",
        "kpiDefinitions",
        "glossary",
        "openQuestions"
      ],
      "properties": {
        "productVision": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextStatement"
          }
        },
        "targetUsers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextStatement"
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextStatement"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextStatement"
          }
        },
        "kpiDefinitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KpiDefinition"
          }
        },
        "glossary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GlossaryTerm"
          }
        },
        "openQuestions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextStatement"
          }
        }
      }
    },
    "decisionReferences": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dlog_[a-zA-Z0-9_-]{3,64}$"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 60
      }
    },
    "compression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isCompressed"],
      "properties": {
        "isCompressed": {
          "type": "boolean"
        },
        "sourceVersionRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fromVersion", "toVersion"],
          "properties": {
            "fromVersion": {
              "type": "integer",
              "minimum": 1
            },
            "toVersion": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "compressionNotes": {
          "type": "string",
          "maxLength": 1200
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    }
  },
  "$defs": {
    "ContextStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{2,6}-[0-9]{1,5}$"
        },
        "statement": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1200
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidenceLinks": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "KpiDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metricId", "metricName", "definition", "cadence"],
      "properties": {
        "metricId": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "metricName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "definition": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1200
        },
        "cadence": {
          "type": "string",
          "enum": ["daily", "weekly", "monthly", "quarterly"]
        },
        "targetDirection": {
          "type": "string",
          "enum": ["increase", "decrease"]
        }
      }
    },
    "GlossaryTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "definition"],
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "definition": {
          "type": "string",
          "minLength": 3,
          "maxLength": 600
        }
      }
    }
  }
}

