  "title": "Shorten onboarding to improve day-7 retention",
  "status": "active",
  "priority": "high",
  "owner": "founder@selectkk.com",
  "hypothesis": "If we reduce onboarding completion time from 8 minutes to under 4 minutes, day-7 retention will increase.",
  "problemStatement": "Users drop off during onboarding because setup requires too many fields and no immediate payoff is shown.",
  "userSegment": "First-time solo founders in their first 14 days",
  "intent": [
    "Reduce onboarding friction",
    "Help users reach first meaningful Bet Spec within 5 minutes"
  ],
  "constraints": [
    "No new backend dependencies in this cycle",
    "Must support mobile web from day one"
  ],
